# Contact form (client-side, Formspree) — safe to be public
NEXT_PUBLIC_FORMSPREE_CONTACT_ID=your_contact_form_id

# Order notifications (server-side only — do NOT add NEXT_PUBLIC_ prefix)
FORMSPREE_ORDER_ID=your_order_form_id

# WhatsApp Business Cloud API (server-side only — never expose these)
# Phone Number ID + Business Account ID: WhatsApp Manager in Meta for Developers
# Access Token: Meta Business Suite → Settings → System Users → Generate token
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_NOTIFY_NUMBER=your_whatsapp_number_without_plus  # e.g. 923045163438

# Telegram Bot (server-side only) — simpler than WhatsApp API
# 1. Message @BotFather → /newbot → get token
# 2. Send /start to your bot → visit api.telegram.org/bot{TOKEN}/getUpdates → find chat.id
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
